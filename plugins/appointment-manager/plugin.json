{
  "name": "appointment-manager",
  "version": "1.0.0",
  "author": "BizForge",
  "description": "Booking links and calendar scheduling",
  "core": true,
  "preinstalled": true,
  "category": "operations",
  "dependsOn": ["customer-crm"],
  "permissions": ["contacts", "calendar", "automation"],
  "activationEvents": ["onStartup", "customer.created"],
  "backendEntry": "src/server/index.ts",
  "frontendEntry": "src/ui/index.tsx",
  "ui": {
    "slots": {
      "dashboard-main": {
        "displayName": "Appointments Overview",
        "layout": "panel",
        "componentRequired": true
      }
    },
    "entry": "ui/dashboard-main.html",
    "exposedComponents": ["dashboard-main"]
  }
}
